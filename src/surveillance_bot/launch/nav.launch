<launch>

  <!-- Load the saved map -->
  <node pkg="map_server" type="map_server" name="map_server" args="$(find surveillance_bot)/maps/my_map.yaml"/>

  <!-- Run your navigator node -->
  <node pkg="surveillance_bot" type="navigator_node.py" name="navigator" output="screen">
    <remap from="/cmd_vel" to="/cmd_vel_mux/input/navi"/>
  </node>

</launch>

